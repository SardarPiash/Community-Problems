# Server
PORT=5000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/cprs

# JWT (SRS Section 12)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# Client URL (for password reset links, FR-1.4)
CLIENT_URL=http://localhost:5173

# Optional SMTP for forgot-password emails (FR-1.4)
# If unset, reset links are logged to the server console in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Set to false to disable optional status-change emails (FR-6.3)
EMAIL_NOTIFICATIONS=true
