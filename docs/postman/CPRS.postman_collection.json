{
  "info": {
    "name": "CPRS - Community Problem Reporting System",
    "description": "REST API for CPRS. Import into Postman. Set `baseUrl`, run Auth > Login, then use other requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "complaintId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "authorityId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Citizen)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Citizen\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"01700000000\",\n  \"password\": \"password1\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@cprs.local\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"citizen1@cprs.local\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"RESET_TOKEN_HERE\",\n  \"password\": \"NewPass123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"01711111111\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users?role=authority"
          }
        },
        {
          "name": "Update User Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"disabled\"\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}/status"
          }
        }
      ]
    },
    {
      "name": "Complaints",
      "item": [
        {
          "name": "Create Complaint (Citizen)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "category", "value": "Road Damage", "type": "text" },
                { "key": "title", "value": "Test pothole", "type": "text" },
                { "key": "description", "value": "Large pothole on main road", "type": "text" },
                { "key": "location", "value": "Main Street", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/api/complaints"
          }
        },
        {
          "name": "My Complaints (Citizen)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/complaints/mine"
          }
        },
        {
          "name": "Get Complaint By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/complaints/{{complaintId}}"
          }
        },
        {
          "name": "List All (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/complaints?status=Pending Verification"
          }
        },
        {
          "name": "Verify Complaint (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"verified\"\n}"
            },
            "url": "{{baseUrl}}/api/complaints/{{complaintId}}/verify"
          }
        },
        {
          "name": "Assign Complaint (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorityId\": \"{{authorityId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/complaints/{{complaintId}}/assign"
          }
        },
        {
          "name": "Assigned Complaints (Authority)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/complaints/assigned"
          }
        },
        {
          "name": "Update Status (Authority)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\",\n  \"note\": \"Work crew dispatched\"\n}"
            },
            "url": "{{baseUrl}}/api/complaints/{{complaintId}}/status"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/notifications"
          }
        },
        {
          "name": "Mark As Read",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/notifications/{{notificationId}}/read"
          }
        }
      ]
    },
    {
      "name": "Analytics (Admin)",
      "item": [
        {
          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/analytics/summary"
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/analytics/export?dateFrom=2026-01-01&dateTo=2026-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "export"],
              "query": [
                { "key": "dateFrom", "value": "2026-01-01" },
                { "key": "dateTo", "value": "2026-12-31" }
              ]
            }
          }
        }
      ]
    }
  ]
}
